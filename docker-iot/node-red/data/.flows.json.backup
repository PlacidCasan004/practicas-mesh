    {
        "id": "8a2c498ee3d59ddc",
        "type": "function",
        "z": "7fb507cca68e61c2",
        "name": "function 1",
        "func": "if (!msg.payload || !msg.payload.mac) {\n    return null;\n}\n\nmsg.mac = msg.payload.mac.trim();\nmsg.topic = \"SELECT * FROM nodos WHERE mac = '\" + msg.mac + \"'\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 660,
        "wires": [
            [
                "7bd0487d6bc22bb3"
            ]
        ]
    },
    {
        "id": "be276125d1fb5089",
        "type": "function",
        "z": "7fb507cca68e61c2",
        "name": "construir respuesta config",
        "func": "if (!msg.payload || msg.payload.length === 0) {\n    return null;\n}\n\nlet row = msg.payload[0];\nlet mac_sin_puntos = row.mac.replace(/:/g, \"\");\n\nmsg.topic = \"mesh/config/\" + mac_sin_puntos;\n\nmsg.payload = {\n    mac: row.mac,\n    tipo_nodo: row.tipo_nodo,\n    sensores: JSON.parse(row.sensores_json || \"[]\"),\n    topic_pub: row.topic_pub,\n    topic_sub: row.topic_sub\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1120,
        "y": 380,
        "wires": [
