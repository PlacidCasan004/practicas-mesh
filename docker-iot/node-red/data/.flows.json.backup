    {
        "id": "79b2e13530987a29",
        "type": "function",
        "z": "7fb507cca68e61c2",
        "name": "SQL temperature",
        "func": "msg.topic = `\nINSERT INTO temperature_measurements\n(node_id, sensor, value, unit, relay_state, mode, layer)\nVALUES (?, ?, ?, ?, ?, ?, ?)\n`;\n\nmsg.payload = [\n    msg.payload.node,\n    msg.payload.sensor,\n    msg.payload.value,\n    msg.payload.unit,\n    msg.payload.relay,\n    msg.payload.mode,\n    msg.payload.layer\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 490,
        "y": 280,
        "wires": [
            [
                "7bd0487d6bc22bb3"
            ]
        ]
    },
